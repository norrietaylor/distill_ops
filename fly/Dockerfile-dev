# Fly.io deployment — staging variant.
#
# Extends the generic Distillery image with the staging config file.
# The image tag is supplied by the staging-deploy workflow and resolves
# to a branch build of the form pr-<N>-sha-<short> pushed by the
# distillery repo's staging-deploy.yml workflow.

ARG IMAGE_TAG=staging

# Static busybox stage — provides /bin/sh and the basic utilities our
# runtime CMD depends on (stat, chown, rm, install, touch, echo, su,
# ln). Upstream distillery images switched to a shell-less base, so
# every `RUN <command>` and the `CMD ["sh", "-c", "..."]` below fail
# without an injected shell. busybox-musl is a single static binary —
# symlinks let the existing scripts work without rewriting the init.
# Track upstream restoration of a POSIX shell in norrietaylor/distillery.
FROM busybox:musl AS shell

FROM ghcr.io/norrietaylor/distillery:${IMAGE_TAG}

USER root

# Inject busybox + symlinks for the applets we use at build/runtime.
# The first RUN is exec form (no shell needed yet) — it execs busybox
# directly to create /bin/sh. After that, shell-form RUN/CMD work.
COPY --from=shell /bin/busybox /usr/local/bin/busybox
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/sh"]
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/chown"]
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/rm"]
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/echo"]
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/su"]
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/stat"]
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/install"]
RUN ["/usr/local/bin/busybox", "ln", "-sf", "/usr/local/bin/busybox", "/bin/touch"]

# FastMCP's OAuth state (registered clients + issued access tokens)
# lives under FASTMCP_HOME — same layout as prod. The staging volume
# is forked from prod's volume, which means /data/fastmcp/* is copied
# along with the DuckDB file. That copy includes prod's entire OAuth
# token store, so without intervention any client already authorised
# against prod would be silently accepted by staging (the local token
# store validates signature + expiry, not issuing OAuth app identity).
#
# The startup script wipes FASTMCP_HOME on the FIRST boot of each
# deploy (detected via a sentinel file) to ensure staging begins with
# a clean OAuth state backed by the separate staging OAuth app, while
# preserving tokens across Fly auto-suspend/resume cycles.
ENV FASTMCP_HOME=/data/fastmcp

# Copy staging-specific config. Owned by uid/gid 65532 (the upstream
# Chainguard `nonroot` user — see distillery#419) so a separate
# build-time recursive chown isn't needed.
COPY --chown=65532:65532 fly/distillery-staging.yaml /app/distillery-staging.yaml
ENV DISTILLERY_CONFIG=/app/distillery-staging.yaml

EXPOSE 8000

# Clear the upstream ENTRYPOINT (`distillery-mcp`) so our CMD runs as
# the literal command. Without this, ENTRYPOINT + CMD concatenate into
# `distillery-mcp sh -c "<our script>"` and argparse exits with code 2.
ENTRYPOINT []

# Fix volume ownership at runtime (only if not already owned — the
# recursive chown gets expensive as the forked DB grows, and on all
# boots after the first of a given deploy it's a no-op), wipe
# inherited FastMCP OAuth state ONCE per deploy, then drop to nonroot.
#
# Ownership check uses uid (`%u`) rather than username (`%U`) so it
# doesn't depend on /etc/passwd resolution succeeding for the comparison.
# 65532 is the upstream Chainguard `nonroot` uid.
#
# The staging volume is forked fresh from prod on every deploy, so the
# first boot must wipe /data/fastmcp to avoid inheriting prod tokens.
# Subsequent boots (e.g. after Fly auto-suspend/resume) skip the wipe
# so that staging OAuth sessions survive machine restarts. A sentinel
# file (/data/fastmcp/.staged) tracks whether the wipe already ran
# for this deploy cycle.
CMD ["sh", "-c", "\
  if [ \"$(stat -c %u /data 2>/dev/null)\" != 65532 ]; then chown -R 65532:65532 /data; fi \
  && if [ ! -f /data/fastmcp/.staged ]; then \
       rm -rf /data/fastmcp \
       && install -d -o 65532 -g 65532 /data/fastmcp \
       && touch /data/fastmcp/.staged; \
     fi \
  && exec su -s /bin/sh nonroot -c 'distillery-mcp --transport http'"]
